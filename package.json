{
  "name": "stylelint-config-htmlacademy",
  "version": "5.0.0",
  "description": "Stylelint Config for HTML Academy CODEGUIDE",
  "keywords": [
    "codeguide",
    "config",
    "htmlacademy",
    "linter",
    "stylelint"
  ],
  "license": "MIT",
  "author": {
    "name": "HTML Academy",
    "email": "mail@htmlacademy.dev",
    "url": "https://htmlacademy.ru"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/htmlacademy/stylelint-config-htmlacademy.git"
  },
  "files": [
    "stylelint.config.js",
    "properties-order.js"
  ],
  "type": "module",
  "exports": "./stylelint.config.js",
  "scripts": {
    "test": "npm run test:lint && npm run test:valid && npm run test:invalid",
    "test:lint": "eslint .",
    "test:invalid": "node --test \"test/invalid/**/*.test.js\"",
    "test:valid": "stylelint \"test/**/*.{css,less,scss}\""
  },
  "dependencies": {
    "@stylistic/stylelint-plugin": "^5.1.0",
    "postcss-less": "^6.0.0",
    "postcss-scss": "^4.0.9",
    "stylelint-order": "^8.1.1"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "eslint-config-htmlacademy": "^11.0.0",
    "globals": "^17.6.0",
    "stylelint": "^17.11.1"
  },
  "peerDependencies": {
    "stylelint": ">=17"
  },
  "engines": {
    "node": ">=24"
  }
}
